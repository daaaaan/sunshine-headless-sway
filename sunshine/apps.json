{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin",
    "SWAYSOCK": "/run/user/1000/sway-sunshine.sock"
  },
  "apps": [
    {
      "name": "Desktop",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "/home/salim/.config/sway-sunshine/restore-default-sink.sh",
          "undo": ""
        },
        {
          "do": "/home/salim/.config/sway-sunshine/set-resolution.sh",
          "undo": "/home/salim/.config/sway-sunshine/reset-resolution.sh"
        }
      ]
    },
    {
      "name": "Steam Big Picture",
      "image-path": "steam.png",
      "prep-cmd": [
        {
          "do": "/home/salim/.config/sway-sunshine/restore-default-sink.sh",
          "undo": ""
        },
        {
          "do": "/home/salim/.config/sway-sunshine/set-resolution.sh",
          "undo": "/home/salim/.config/sway-sunshine/reset-resolution.sh"
        }
      ],
      "cmd": "swaymsg exec 'steam steam://open/bigpicture'",
      "auto-detach": true
    }
  ]
}
